# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# HADITH_API_KEY: Required for Hadith API calls.
# Get your key from https://www.hadithapi.com/
# Use VITE_HADITH_API_KEY for client-side access in Vite
VITE_HADITH_API_KEY="YOUR_HADITH_API_KEY"
HADITH_API_KEY="YOUR_HADITH_API_KEY"

# SUNNAH.COM API: Required for Sunnah.com API
# Get your key from https://sunnah.com/news/api-documentation-is-live (or their developer portal)
VITE_SUNNAH_API_KEY="YOUR_SUNNAH_API_KEY"

# Quran Foundation API (for User/Member features)
QURAN_FOUNDATION_CLIENT_ID=
QURAN_FOUNDATION_CLIENT_SECRET=
QURAN_FOUNDATION_BASE_URL=https://api.quran.com/api/v4
